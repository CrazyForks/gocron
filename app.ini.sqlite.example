# gocron SQLite 配置示例
# 将此文件复制到 ~/.gocron/conf/app.ini 并修改相应配置

[default]
# 数据库配置 - SQLite
db.engine=sqlite
# SQLite 数据库文件路径（相对路径或绝对路径）
# 相对路径：相对于程序运行目录
# 绝对路径：/path/to/gocron.db 或 ~/.gocron/data/gocron.db
db.database=./data/gocron.db
# SQLite 不需要以下配置，但保留以兼容配置文件格式
db.host=
db.port=
db.user=
db.password=
db.charset=utf8
db.prefix=
db.max.idle.conns=30
db.max.open.conns=100

# 应用配置
app.name=定时任务管理系统
# 服务端默认语言（zh / en），可选，默认 en：影响调度器、RPC 等后台场景产生并写入日志的消息语言。
# 仅对之后新产生的日志生效，已有日志不会被重新翻译。需要中文日志时取消下面一行注释。
# app.lang=zh

# API配置
api.key=
api.secret=
api.sign.enable=true

# MCP 远程接入（供 AI 客户端通过 MCP 协议管理任务）
# 端点为 /mcp，使用「系统管理 - MCP 密钥」中创建的 Bearer 令牌鉴权
# 务必置于 HTTPS / 反向代理之后再对外暴露
mcp.enable=true

# 允许访问的IP列表，多个IP用逗号分隔，为空表示不限制
allow_ips=

# 并发队列大小
concurrency.queue=500

# 认证密钥（自动生成，无需手动配置）
auth_secret=

# TLS配置
enable_tls=false
ca_file=
cert_file=
key_file=
