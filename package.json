{
  "name": "gocron",
  "version": "2.0.0",
  "description": "定时任务管理系统",
  "author": "gocronx <gocronx@gmail.com>",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "commit": "git-cz",
    "lint:lint-staged": "lint-staged"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "web/vue/**/*.{js,ts,vue}": [
      "cd web/vue && pnpm exec eslint --fix",
      "cd web/vue && pnpm exec prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "cd web/vue && pnpm exec prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "tmp@<0.2.4": "0.2.4",
      "flatted": ">=3.4.2"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
